<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Passport_Number</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  NOT(ISBLANK(Passport_Number__c)),
  NOT(REGEX(UPPER(Passport_Number__c), &quot;^[A-Z]{1}[0-9]{7}$&quot;))
)</errorConditionFormula>
    <errorDisplayField>Passport_Number__c</errorDisplayField>
    <errorMessage>Enter a valid passport number (Format: A1234567).</errorMessage>
</ValidationRule>
