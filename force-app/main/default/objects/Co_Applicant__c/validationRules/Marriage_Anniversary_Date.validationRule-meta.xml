<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Marriage_Anniversary_Date</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    ISPICKVAL(Marital_Status__c, &quot;Married&quot;),
    NOT(ISBLANK(Anniverssary_Date__c)),
    Anniverssary_Date__c &gt; TODAY()
)</errorConditionFormula>
    <errorDisplayField>Marital_Status__c</errorDisplayField>
    <errorMessage>Anniversary date cannot be in the future.</errorMessage>
</ValidationRule>
