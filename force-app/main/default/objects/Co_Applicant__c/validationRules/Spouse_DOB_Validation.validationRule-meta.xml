<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Spouse_DOB_Validation</fullName>
    <active>true</active>
    <errorConditionFormula>NOT(
    ISBLANK(Spouse_Date_Of_Birth_coapp__c)
)
&amp;&amp;
(
    Spouse_Date_Of_Birth_coapp__c &gt; (TODAY() - (18 * 365))
)</errorConditionFormula>
    <errorMessage>Spouse DOB should be greater than 18</errorMessage>
</ValidationRule>
