<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Indutry_Validation</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    Industry__c == &apos;Other&apos;,
    ISBLANK(Other_Profession__c)
)</errorConditionFormula>
    <errorDisplayField>Other_Profession__c</errorDisplayField>
    <errorMessage>Please Fill Other Industry</errorMessage>
</ValidationRule>
