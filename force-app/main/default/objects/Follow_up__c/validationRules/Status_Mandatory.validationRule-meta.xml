<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Status_Mandatory</fullName>
    <active>false</active>
    <errorConditionFormula>AND(
    ISPICKVAL(Status__c, &apos;Completed&apos;), 
    ISPICKVAL(Expected_Follow_Up__c,&apos;&apos;) 
)</errorConditionFormula>
    <errorDisplayField>Expected_Follow_Up__c</errorDisplayField>
    <errorMessage>Please Fill Next Follow Status</errorMessage>
</ValidationRule>
