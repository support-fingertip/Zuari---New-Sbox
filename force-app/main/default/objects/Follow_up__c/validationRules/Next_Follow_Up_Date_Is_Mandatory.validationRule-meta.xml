<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Next_Follow_Up_Date_Is_Mandatory</fullName>
    <active>false</active>
    <errorConditionFormula>AND(
    ISPICKVAL(Expected_Follow_Up__c, &apos;Continue Follow Up&apos;),
    ISBLANK(Next_Follow_Up_Date__c)
)</errorConditionFormula>
    <errorDisplayField>Next_Follow_Up_Date__c</errorDisplayField>
    <errorMessage>Please Fill The Next Follow Up date</errorMessage>
</ValidationRule>
