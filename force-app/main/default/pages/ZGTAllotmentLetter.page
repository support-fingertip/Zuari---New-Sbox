<apex:page standardController="Booking__c" renderAs="pdf" extensions="AllotmentLetterController" showHeader="false" cache="true" readOnly="true" applyHtmlTag="false" applyBodyTag="false">
    <html>
        <head>
            <style type="text/css">
                @page {
                margin: 20mm 15mm 20mm 15mm;
                }
                
                body {
                font-family: Times New Roman;
                font-size: 15px;
                color: #000;
                }
                
                table {
                border-collapse: collapse;
                width: 100%;
                }
                
                .no-border, .no-border td {
                border: none !important;
                }
                
                .title {
                text-align: center;
                font-weight: bold;
                font-size: 20px;
                margin: 10px 0 15px 0;
                }
                
                .title span {
                border-bottom: 1px solid #000;
                padding-bottom: 3px;
                }
                
                .date-row {
                text-align: right;
                margin: 10px 100px 15px 0;
                font-size: 14px;
                }
                
                .to-block {
                margin-top: 10px;
                line-height: 18px;
                font-size: 14px;
                }
                .page-break { page-break-before: always; }
            </style>
        </head>
        
        <body>
            <!-- Header Logos -->
            <table class="no-border">
                <tr>
                    <td style="text-align:left;">
                        <img src="{!URLFOR($Resource.Zuari)}" width="150" height="60" />
                    </td>
                    <td style="text-align:right;">
                        <apex:image url="{!projectLogoUrl}" width="140" height="80" rendered="{!NOT(ISBLANK(projectLogoUrl))}" />
                    </td>
                </tr>
            </table>
            
            <!-- Title -->
            <div class="title">
                <span>Provisional Allotment Letter</span>
            </div>
            <br/>
            <!-- Date -->
            <div class="date-row">
                Date : &nbsp;<apex:outputText value="{0,date,dd-MM-yyyy}"><apex:param value="{!TODAY()}" /></apex:outputText>
            </div>
            
            <!-- To Address -->
            <div class="to-block">
                To,<br/>
                <div>
                    <div>Applicant's Name :&nbsp;&nbsp;&nbsp;&nbsp;{!Booking__c.S__c} {!Booking__c.First_Applicant_Name__c}</div>
                    <div>
                        <apex:outputPanel rendered="{!NOT(ISBLANK(firstCoApplicant.Name))}">Co Applicant's Name : {!firstCoApplicant.Salutation__c} {!firstCoApplicant.Name}</apex:outputPanel>
                        <div>Applicant's Address :&nbsp;{!PermanentFullAddress}</div>
                    </div>
                </div>
            </div>
            
            <p>
                <b>Sub :</b> Allotment of {!unitLabel} No. {!booking__c.Unit_No__c}, Phase {!booking__c.Quote__r.Unit__r.Phase_Detail__c} in Block {!booking__c.Quote__r.Unit__r.Tower__c} <b>{!projectName},</b> Kollur, Hyderabad-508101.
            </p>
            
            <b>Dear Sir,</b><br/>
            
            <table style="width:100%; font-size:14px; font-family: 'Times New Roman', Times, serif;">
                <tr>
                    <td style="text-align: justify; line-height: 1.5; padding-top:8px;">
                        <table style="width:100%; border-spacing: 0 3px;">
                            <tr>
                                <td style="width:30px; vertical-align:top;"><b>1.</b></td>
                                <td style="line-height: 1.5;">With reference to your application for allotment of a {!booking__c.Quote__r.Unit__r.BHK_Type__c} in {!projectName}, Kollur, Hyderabad, India, {!projectName} is pleased to provisionally allot <b>("Allotment")</b> a {!booking__c.Quote__r.Unit__r.BHK_Type__c} bearing {!unitLabel} No. {!booking__c.Unit_No__c} <b>("{!unitLabel}")</b>, Phase {!booking__c.Quote__r.Unit__r.Phase_Detail__c} having a Super Built Up area of {!Booking__c.Quote__r.Super_Built_UpArea__c} square feet in our Project, {!projectName}, Kollur, Hyderabad – along with the proportionate undivided share, interest and right in the immoveable property.</td>
                            </tr>
                            <tr>
                                <td style="width:30px; vertical-align:top;"><b>2.</b></td>
                                <td style="line-height: 1.5;">{!projectName} acknowledges that it has received a sum of <b>Rs. {!Booking__c.Total_received_Amount__c}/- (Rupees {!totalReceivedInWords} only)</b> from you till the milestone completion at site.</td>
                            </tr>
                            <tr>
                                <td style="width:30px; vertical-align:top;"><b>3.</b></td>
                                <td style="line-height: 1.5;">This Allotment is subject to the fulfillment of the terms and conditions set out here in which shall prevail over all other terms and conditions set out in any publicity material, price lists and other documents including correspondence, if any, between us.</td>
                            </tr>
                            <tr>
                                <td style="width:30px; vertical-align:top;"><b>4.</b></td>
                                <td style="line-height: 1.5;">The total sale consideration (<b>"Consideration"</b>) for the purchase of the {!LOWER(unitLabel)} is fixed at <b>Rs. {!Booking__c.Quote__r.GRAND_TOTAL__c}/- (Rupees {!grandTotalInWords} only)</b> which includes Base cost, Car park, Club House membership charges, Legal Maintenance Charges Excluding GST prevailing taxes.</td>
                            </tr>
                        </table>
                    </td>
                </tr>
            </table>
            
            <!-- Unit Details -->
            <div>
                <b style="text-decoration: underline;">{!unitLabel} Details</b><br/><br/>
                <table style="width:100%; font-family: 'Times New Roman', Times, serif; font-size:14px; border: 1px solid black; border-collapse: collapse;">
                    <tr>
                        <td style="border: 1px solid black; padding: 8px; width: 40%;">Project</td>
                        <td style="border: 1px solid black; padding: 8px; width: 60%;">{!projectName}</td>
                    </tr>
                    <tr>
                        <td style="border: 1px solid black; padding: 8px;">Phase</td>
                        <td style="border: 1px solid black; padding: 8px;">{!booking__c.Quote__r.Unit__r.Phase_Detail__c}</td>
                    </tr>
                    <tr>
                        <td style="border: 1px solid black; padding: 8px;">Tower</td>
                        <td style="border: 1px solid black; padding: 8px;">{!booking__c.Quote__r.Unit__r.Tower__c}</td>
                    </tr>
                    <tr>
                        <td style="border: 1px solid black; padding: 8px;">{!unitLabel} No</td>
                        <td style="border: 1px solid black; padding: 8px;">{!booking__c.Unit_No__c}</td>
                    </tr>
                    <tr>
                        <td style="border: 1px solid black; padding: 8px;">Flat Type</td>
                        <td style="border: 1px solid black; padding: 8px;">{!booking__c.Quote__r.Unit__r.BHK_Type__c}</td>
                    </tr>
                    <tr>
                        <td style="border: 1px solid black; padding: 8px;">Super Built Up Area of Unit</td>
                        <td style="border: 1px solid black; padding: 8px;"><b>{!Booking__c.Quote__r.Super_Built_UpArea__c} SqFt / {!ROUND(Booking__c.Quote__r.Super_Built_UpArea__c * 0.092903, 2)} SqMt</b></td>
                    </tr>
                </table>
            </div>
            
            <div class="page-break"></div>
            
            <!-- Payment Schedule -->
            <p>
                <b style="text-decoration: underline;">Payment Schedule:</b>
            </p>
            <div>
                Payment adjustment will be as per milestone completion.<br/><br/>
                
                <apex:variable value="{!0}" var="counter" />
                <table style="width:100%; border-collapse:collapse; font-family:'Times New Roman', Times, serif; font-size:14px;">
                    <tr>
                        <th style="border:1px solid #000; padding:6px; text-align:center;">Sl. No.</th>
                        <th style="border:1px solid #000; padding:6px; text-align:center;">Milestones Schedule</th>
                        <th style="border:1px solid #000; padding:6px; text-align:center;">Percentage</th>
                    </tr>
                    
                    <!-- Row 1 - STATIC Booking -->
                    <tr>
                        <td style="border:1px solid #000; padding:6px; text-align:center;">1.</td>
                        <td style="border:1px solid #000; padding:6px; text-align:center; font-weight:bold;">Booking</td>
                        <td style="border:1px solid #000; padding:6px; text-align:center;">Rs. {!Booking__c.Booking_Amount__c}/-</td>
                    </tr>
                    
                    <!-- Dynamic Payment Schedules (start from 2) -->
                    <apex:repeat value="{!paymentSchedules}" var="ps">
                        <apex:variable var="counter" value="{!counter + 1}" />
                        <tr>
                            <td style="border:1px solid #000; padding:6px; text-align:center;">
                                {!counter + 1}.
                            </td>
                            <td style="border:1px solid #000; padding:6px; text-align:left;">
                                <span style="font-weight:bold;">
                                    {!ps.Name} – Payment Due
                                </span>
                            </td>
                            <td style="border:1px solid #000; padding:6px; text-align:center;">
                                {!ps.Payment_percent__c}%
                            </td>
                        </tr>
                    </apex:repeat>
                </table>
                
                <br/><br/>
                
                <!-- Note Section -->
                <p>
                    <b style="text-decoration: underline;">Note:</b>
                </p>
                <table style="width:100%; font-family:'Times New Roman', Times, serif; font-size:14px; border-collapse:collapse;">
                    <tr>
                        <td style="width:25px; vertical-align:top;"><b>1.</b></td>
                        <td style="line-height:1.5; text-align:justify;">
                            The schedule set out above includes the following costs:
                            <ul style="margin-top:5px;">
                                <li>Super built-up area</li>
                                <li>Electrification and water supply charges calculated at the rate mentioned under 'Consideration Summary'.</li>
                                <li>Legal Fees, payable at the time of obtaining possession of the Unit</li>
                                <li>Club House Membership Charges along with necessary taxes payable at the time of completion of the first floor slab of the Unit</li>
                                <li>Maintenance Deposit for 2 (Two) yrs, payable at the time of obtaining possession of the Unit</li>
                                <li>View Charges, if applicable, calculated at the rate mentioned under 'Consideration Summary'</li>
                                <li>Taxes calculated at the prevailing rates for each installment.</li>
                            </ul>
                        </td>
                    </tr>
                    <tr>
                        <td style="width:25px; vertical-align:top;"><b>2.</b></td>
                        <td style="line-height:1.5; text-align:justify;">
                            The Allotment of the {!LOWER(unitLabel)} is only provisional and shall be subject to fulfillment of the following terms and conditions:
                        </td>
                    </tr>
                </table>
                
                <br/>
                
                <!-- Terms and Conditions -->
                <table style="width:100%; font-family:'Times New Roman', Times, serif; font-size:14px; border-collapse:collapse;">
                    <tr>
                        <td style="width:35px; vertical-align:top;"><b>i.</b></td>
                        <td style="line-height:1.5; text-align:justify;">
                            All Allotments are subject to amendment of the sanction plan by the Hyderabad Metropolitan Development Authority ("HMDA"), if any.
                        </td>
                    </tr>
                    <tr>
                        <td style="vertical-align:top;"><b>ii.</b></td>
                        <td style="line-height:1.5; text-align:justify;">
                            The dimensions, area and boundaries of the {!LOWER(unitLabel)} are based on the sanctioned plan approved by HMDA. There may be certain alterations to the same based on further amendments to the sanction plan. You shall be required to give effects to such alterations and amendments, without any demur or protest whatsoever.
                        </td>
                    </tr>
                    <tr>
                        <td style="vertical-align:top;"><b>iii.</b></td>
                        <td style="line-height:1.5; text-align:justify;">
                            The Allotment of the {!LOWER(unitLabel)} on the basis of the application filed by you is entirely at the discretion of {!projectName} and {!projectName} has a right to reject any application without assigning any reason.
                        </td>
                    </tr>
                    <tr>
                        <td style="vertical-align:top;"><b>iv.</b></td>
                        <td style="line-height:1.5; text-align:justify;">
                            This Allotment letter is only provisional.
                        </td>
                    </tr>
                    <tr>
                        <td style="vertical-align:top;"><b>v.</b></td>
                        <td style="line-height:1.5; text-align:justify;">
                            If opted for, premium location charges, calculated at the rate mentioned in Consideration Summary per square foot of the super-built area, along with Taxes at applicable rate, shall be charged on corner and park facing {!LOWER(unitLabel)}s in the Project.
                        </td>
                    </tr>
                    <tr>
                        <td style="vertical-align:top;"><b>vi.</b></td>
                        <td style="line-height:1.5; text-align:justify;">
                            All payments should be made on time and in such time intervals as provided in this Allotment letter.
                        </td>
                    </tr>
                    <tr>
                        <td style="vertical-align:top;"><b>vii.</b></td>
                        <td style="line-height:1.5; text-align:justify;">
                            All payments to {!projectName} are to be either made by way of demand draft or account payee cheques favouring {!Booking__c.Project1__r.Cheque_Favoring_Name__c}, payable at Hyderabad, A/c No. {!Booking__c.Project1__r.Account_Number__c} drawn on {!Booking__c.Project1__r.Bank_Name__c} Bank, {!Booking__c.Project1__r.Branch__c} Branch, Hyderabad – or by way of electronic fund transfer, RTGS/NEFT/IFSC: {!Booking__c.Project1__r.IFSC_code__c}, such electronic fund transfer being done after prior intimation to Zuari in writing.
                        </td>
                    </tr>
                    
                    <div class="page-break"></div>
                    
                    <tr>
                        <td style="vertical-align:top;"><b>viii.</b></td>
                        <td style="line-height:1.5; text-align:justify;">
                            Payments by cheque in favor of Gangothri Infraedge Pvt Ltd will be subject to realization. If any cheque received by {!projectName} towards the Consideration is dishonored, you shall be bound to make such payment by way of a demand draft within a period of 15 (fifteen) days from the date of the dishonor of the cheque.
                        </td>
                    </tr>
                    <tr>
                        <td style="vertical-align:top;"><b>ix.</b></td>
                        <td style="line-height:1.5; text-align:justify;">
                            Interest at the applicable rate per annum will be applicable for the delayed payments beyond 30 days from the date of the demand letter.
                        </td>
                    </tr>
                    <tr>
                        <td style="vertical-align:top;"><b>x.</b></td>
                        <td style="line-height:1.5; text-align:justify;">
                            This Allotment letter does not create any right, title or interest over the {!LOWER(unitLabel)}, until and unless a registered sale deed has been executed by {!projectName} in your favor.
                        </td>
                    </tr>
                    <tr>
                        <td style="vertical-align:top;"><b>xi.</b></td>
                        <td style="line-height:1.5; text-align:justify;">
                            You shall bear the stamp duty and registration fees for the execution of the agreement to sell, construction agreement and the sale deed, and {!projectName} shall not be liable to bear any such costs, whether direct or ancillary, to the execution and registration of the above documents.
                        </td>
                    </tr>
                    <tr>
                        <td style="vertical-align:top;"><b>xii.</b></td>
                        <td style="line-height:1.5; text-align:justify;">
                            If the {!LOWER(unitLabel)} is being booked on behalf of a person other than you, you shall be required to provide a duly executed power of attorney or other authorization in your favor to {!projectName} at the time of the execution of the agreement to sell and the construction agreement. If the {!LOWER(unitLabel)} is being purchased by any person, other than a natural person, necessary legal documents relating to its existence etc., as may be requested by {!projectName} shall be provided at the time of the execution of the agreement to sell and construction agreement.
                        </td>
                    </tr>
                    <tr>
                        <td style="vertical-align:top;"><b>xiii.</b></td>
                        <td style="line-height:1.5; text-align:justify;">
                            Any Allotment may be cancelled within 15 (fifteen) days from the date of this Allotment at your option. If you seek to cancel this Allotment within a period of 15 (fifteen) days from the date of Allotment, an amount equivalent as prescribed in rules shall be deducted as cancellation charges by {!projectName} and the balance amount, if any, will be refunded to you within a reasonable time.
                        </td>
                    </tr>
                    <tr>
                        <td style="vertical-align:top;"><b>xiv.</b></td>
                        <td style="line-height:1.5; text-align:justify;">
                            Without the prior written consent of {!projectName}, you shall not be entitled to assign/transfer any right, title and interest under this Allotment to a third party. It is clarified that Zuari is not obliged to give its consent for any assignment by you, and should Zuari accord its consent to the assignment of this Allotment by you, the same may be accorded with such conditions as Zuari may deem fit. Provided however that you may, with prior written intimation to {!projectName} in this regard, assign your entire right, title and interest under this Allotment to a blood relative. No partial assignment by you of any right, title or interest under this Allotment would be permitted (including to a blood relative). After the assignment of this Allotment, such third-party shall continue to make payments with respect to the Consideration in the manner set out in this Allotment letter.
                        </td>
                    </tr>
                    <tr>
                        <td style="vertical-align:top;"><b>xv.</b></td>
                        <td style="line-height:1.5; text-align:justify;">
                            Any assignment by you of this Allotment to a third party for which {!projectName} has given its written consent shall be at an additional charge of Rs. 200 (Rupees Two Hundred only) per square feet plus applicable GST calculated on the super built-up area of the {!LOWER(unitLabel)} and payable by you to {!projectName}.
                        </td>
                    </tr>
                    <tr>
                        <td style="vertical-align:top;"><b>xvi.</b></td>
                        <td style="line-height:1.5; text-align:justify;">
                            Any dispute arising out of this Allotment, including interpretation of this Allotment letter shall be resolved by binding arbitration in accordance with the procedure provided under the Arbitration and Conciliation Act, 1996. The arbitral tribunal shall consist of a sole arbitrator, to be appointed by {!projectName} and the seat of arbitration shall be at Hyderabad. The costs of such arbitration shall be borne by the losing party.
                        </td>
                    </tr>
                </table>
                
                <br/><br/>
                
                <div>
                    Should you accept the terms and conditions set forth in this Allotment letter, kindly sign and return a copy of this to us in token of your acceptance.
                </div>
                
                <br/><br/><br/><br/>
                
                <table style="width:100%; font-family:'Times New Roman', Times, serif; font-size:14px;">
                    <tr>
                        <td style="text-align:left; line-height:1.5;">
                            <b>Yours faithfully,</b><br/><br/>
                            <b>Authorized Signatory</b><br/><br/>
                            <b>Gangothri Infraedge Pvt Ltd</b>
                        </td>
                    </tr>
                </table>
            </div>
        </body>
    </html>
    
</apex:page>