<apex:page renderAs="pdf" standardController="Booking__c" extensions="ZGTstatementOfAccountsController" showHeader="false" sidebar="false" applyHtmlTag="false" applyBodyTag="false" standardStylesheets="false">
    <head>
        <style>
            @page {
            size: A4;
            margin: 40px 40px 40px 40px;
            }
            
            body {
            font-family: 'Times New Roman', serif;
            font-size: 12px;
            color: #000;
            padding: 10px;
            border: 1.5px solid #000;
            }
            
            .title {
            text-align: center;
            font-weight: bold;
            font-size: 13px;
            padding: 10px 0 15px 0;
            }
            
            .info-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 10px;
            }
            
            .info-table td {
            border: none;
            padding: 2px 5px;
            font-size: 10px;
            vertical-align: top;
            }
            
            .info-label {
            font-weight: bold;
            width: 15%;
            }
            
            .info-value {
            width: 35%;
            border-bottom: 1px solid #ccc;
            }
            
            .info-label-right {
            font-weight: bold;
            width: 15%;
            }
            
            .info-value-right {
            width: 35%;
            border-bottom: 1px solid #ccc;
            }
            
            .cost-table {
            width: 50%;
            border-collapse: collapse;
            margin: 15px 0;
            table-layout: fixed;
            }
            
            .cost-table td {
            border: 1px solid #000;
            padding: 3px 5px;
            font-size: 10px;
            }
            
            .cost-table td:first-child {
            width: 70%;
            }
            
            .cost-table td:last-child {
            width: 30%;
            }
            
            .schedule-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 15px;
            }
            
            .schedule-table th {
            border: 1px solid #000;
            padding: 4px 5px;
            font-size: 10px;
            font-weight: bold;
            text-align: center;
            }
            
            .schedule-table td {
            border: 1px solid #000;
            padding: 3px 5px;
            font-size: 10px;
            }
            
            .receipt-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 10px;
            }
            
            .receipt-table th {
            border: 1px solid #000;
            padding: 4px 5px;
            font-size: 10px;
            font-weight: bold;
            text-align: center;
            }
            
            .receipt-table td {
            border: 1px solid #000;
            padding: 3px 5px;
            font-size: 10px;
            }
            
            .total-row td {
            font-weight: bold;
            }
            
            .amount-highlight {
            background-color: #F4A460;
            font-weight: bold;
            text-align: right;
            }
            
            .note-section {
            margin-top: 15px;
            font-size: 10px;
            }
            
            .note-section p {
            margin: 2px 0;
            }
        </style>
    </head>
    
    <body>
        
        <!-- Logos Inside Border -->
        <table width="100%" cellpadding="0" cellspacing="0" style="width: 100%;">
            <tr>
                <td style="text-align: left; border: none; width: 50%;">
                    <img src="{!$Resource.Zuari}" width="110px" height="50" />
                </td>
                <td style="text-align: right; border: none; width: 50%;">
                    <apex:outputText rendered="{!booking.Project1__r.Name == 'Zuari Garden City - Plots'}">
                        <img src="{!$Resource.ZuariGardenCity}" width="110px" height="50" />
                    </apex:outputText>
                    <apex:outputText rendered="{!booking.Project1__r.Name == 'Zuari Gangotri Tribhuja'}">
                        <img src="{!$Resource.GangotriLogo}" width="110px" height="50" />
                    </apex:outputText>
                </td>
            </tr>
        </table>
        
        <!-- Title -->
        <div class="title">ZGT - Statement of Accounts</div>
        
        <!-- Personal Info Section -->
        <table class="info-table">
            <tr>
                <td class="info-label">{!booking.S__c}&nbsp;{!booking.First_Applicant_Name__c}</td>
                <td class="info-value">&nbsp;</td>
                <td class="info-label-right">Flat No:</td>
                <td class="info-value-right">{!booking.Plot__r.Name}</td>
            </tr>
            <tr>
                <td class="info-label">Address:</td>
                <td class="info-value">{!permanentFullAddress}</td>
                <td class="info-label-right">Phase:</td>
                <td class="info-value-right">{!booking.Plot__r.Phase_Detail__c}</td>
            </tr>
            <tr>
                <td class="info-label"></td>
                <td class="info-value"></td>
                <td class="info-label-right">BHK Type:</td>
                <td class="info-value-right">{!booking.Plot__r.BHK_Type__c}</td>
            </tr>
            <tr>
                <td class="info-label">Mobile No.</td>
                <td class="info-value">{!booking.Mobile__c}</td>
                <td class="info-label-right">Floor:</td>
                <td class="info-value-right">{!booking.Plot__r.Floor__c}</td>
            </tr>
            <tr>
                <td class="info-label">Email Id:</td>
                <td class="info-value">{!booking.Email__c}</td>
                <td class="info-label-right">Tower:</td>
                <td class="info-value-right">{!booking.Plot__r.Block_Lookup__r.Name}</td>
            </tr>
            <tr>
                <td class="info-label">PAN No.</td>
                <td class="info-value">{!booking.PAN_Number__c}</td>
                <td class="info-label-right">SBA:</td>
                <td class="info-value-right">{!booking.Plot__r.Super_Built_up_Area__c} </td>
            </tr>
            <tr>
                <td class="info-label">Aadhar No.</td>
                <td class="info-value">{!booking.Aadhar_No__c}</td>
                <td class="info-label-right">Carpet Area:</td>
                <td class="info-value-right">{!booking.Plot__r.Carpet_Area_in_SFT__c} </td>
            </tr>
            <tr>
                <td class="info-label"></td>
                <td class="info-value"></td>
                <td class="info-label-right">Booking Date:</td>
                <td class="info-value-right">
                    <apex:outputText value="{0,date,dd/MM/yyyy}">
                        <apex:param value="{!booking.Booking_Date__c}"/>
                    </apex:outputText>
                </td>
            </tr>
            <tr>
                <td class="info-label"></td>
                <td class="info-value"></td>
                <td class="info-label-right">Agreement Date:</td>
                <td class="info-value-right">
                    <apex:outputText value="{0,date,dd/MM/yyyy}">
                        <apex:param value="{!booking.Agreement_Executed_Date__c}"/>
                    </apex:outputText>
                </td>
            </tr>
        </table>
        
        <!-- Cost Breakdown -->
        <table class="cost-table">
            <tr>
                <td>Sale Agreement Value</td>
                <td style="text-align: right;">
                    <apex:outputText value="₹ {0, number, ##,##,##0.00}">
                        <apex:param value="{!booking.Agreement_Value__c}" />
                    </apex:outputText>
                </td>
            </tr>
            <tr>
                <td>GST on Agreement Value</td>
                <td style="text-align: right;">
                    <apex:outputText value="₹ {0, number, ##,##,##0.00}">
                        <apex:param value="{!booking.Quote__r.GST_On_agreement_Value_Actual__c}" />
                    </apex:outputText>
                </td>
            </tr>
            <tr>
                <td>Other Charges</td>
                <td style="text-align: right;">
                    <apex:outputText value="₹ {0, number, ##,##,##0.00}">
                        <apex:param value="{!totalOtherCharges}" />
                    </apex:outputText>
                </td>
            </tr>
            <tr>
                <td>GST on Other Charges</td>
                <td style="text-align: right;">
                    <apex:outputText value="₹ {0, number, ##,##,##0.00}">
                        <apex:param value="{!booking.Quote__r.GST_On_Other_Charges_Actual__c}" />
                    </apex:outputText>
                </td>
            </tr>
            <tr>
                <td style="font-weight: bold;">Total Cost of the Flat</td>
                <td style="text-align: right; font-weight: bold;">
                    <apex:outputText value="₹ {0, number, ##,##,##0.00}">
                        <apex:param value="{!booking.Quote__r.GRAND_TOTAL__c}" />
                    </apex:outputText>
                </td>
            </tr>
        </table>
        
        <!-- Schedule of Payment -->
        <table class="schedule-table">
            <tr>
                <td colspan="5" style="text-align: center; font-weight: bold; font-size: 11px; border: 1px solid #000;">SCHEDULE OF PAYMENT</td>
            </tr>
            <tr>
                <th style="width: 5%;">Sl No</th>
                <th style="width: 40%;">Payment Milestone</th>
                <th style="width: 15%;">Milestone Percentage(%)</th>
                <th style="width: 20%;">Milestone Value</th>
                <th style="width: 20%;">Payment Received</th>
            </tr>
            
            <apex:repeat value="{!paymentScheduleList}" var="ps">
                <tr>
                    <td style="text-align: center;">
                        <apex:outputText value="{!ps.S_No__c}" />
                    </td>
                    <td>
                        <apex:outputText value="{!ps.Name}" />
                    </td>
                    <td style="text-align: center;">
                        <apex:outputText value="{0, number, 0}%">
                            <apex:param value="{!ps.Payment_percent__c}" />
                        </apex:outputText>
                    </td>
                    <td style="text-align: right;">
                        <apex:outputText value="{0, number, ##,##,##0.00}">
                            <apex:param value="{!ps.Total_Payable_Amount__c}" />
                        </apex:outputText>
                    </td>
                    <td style="text-align: right;">
                        <apex:outputText value="{0, number, ##,##,##0.00}">
                            <apex:param value="{!ps.Received_Amount1__c}" />
                        </apex:outputText>
                    </td>
                </tr>
            </apex:repeat>
            
            <tr class="total-row">
                <td></td>
                <td>Total</td>
                <td style="text-align: center;">100%</td>
                <td style="text-align: right;"></td>
                <td style="text-align: right;"></td>
            </tr>
        </table>
        
        <!-- Receipt of the Payment -->
        <table class="receipt-table">
            <tr>
                <td colspan="7" style="text-align: center; font-weight: bold; font-size: 11px; border: 1px solid #000;">Receipt of the Payment</td>
            </tr>
            <tr>
                <th>Cheque No</th>
                <th>Dated</th>
                <th>Transaction Reference No</th>
                <th>Bank</th>
                <th>Receipt No</th>
                <th>Date</th>
                <th>Amount</th>
            </tr>
            <apex:repeat value="{!receiptList}" var="r">
                <tr>
                    <td style="text-align: center;">
                        <apex:outputText value="{!r.Check_Transaction_Nmber__c}" />
                    </td>
                    <td style="text-align: center;">
                        <apex:outputText value="{0,date,dd-MMM-yy}">
                            <apex:param value="{!r.Receipt_Date__c}"/>
                        </apex:outputText>
                    </td>
                    <td style="text-align: center;">
                        <apex:outputText value="{!r.Check_Transaction_Nmber__c}" />
                    </td>
                    <td style="text-align: center;">
                        <apex:outputText value="{!receiptLineItemMap[r.Id].Bank_Name__c}" />
                    </td>
                    <td style="text-align: center;">{!r.Name}</td>
                    <td style="text-align: center;">
                        <apex:outputText value="{0,date,dd-MMM-yy}">
                            <apex:param value="{!r.Receipt_Date__c}"/>
                        </apex:outputText>
                    </td>
                    <td style="text-align: right;">{!r.Total_Received_Amount__c}</td>
                </tr>
            </apex:repeat>
            <!-- Total Row -->
            <tr>
                <td colspan="5" style="border: none;"></td>
                <td style="font-weight: bold; text-align: right;">Total</td>
                <td class="amount-highlight">{!totalReceiptAmount}</td>
            </tr>
        </table>
        
        <!-- Note Section -->
        <div class="note-section">
            <p><strong>Note :</strong></p>
            <br/>
            <p>1 &nbsp; Total interest incurred due to delay in payment</p>
            <p>2 &nbsp; Total interest amount received</p>
            <p>3 &nbsp; Total interest amount is waived off</p>
            <p>4 &nbsp; Total interest amount is due for payment</p>
        </div>
        
    </body>
</apex:page>