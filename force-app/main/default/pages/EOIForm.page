<script type="text/javascript">
(function() {
    var files = {};
    function $(id){ return document.getElementById(id); }
    function show(el){ el.classList.remove('hidden'); }
    function hide(el){ el.classList.add('hidden'); }
    function showError(msg){ var e=$('eoiError'); e.textContent=msg; show(e); window.scrollTo({top:0,behavior:'smooth'}); }
    function clearError(){ hide($('eoiError')); }

    function bindOther(selectId, wrapId){
        var sel=$(selectId); if(!sel) return;
        sel.addEventListener('change', function(){
            var v=(sel.value||'').toLowerCase();
            if(v.indexOf('other')>=0){ show($(wrapId)); } else { hide($(wrapId)); }
        });
    }
    bindOther('qualSelect','otherQualWrap');
    bindOther('purposeSelect','otherPurposeWrap');
    bindOther('howKnowSelect','otherSourceWrap');

    function refreshDpdp(){
        var sal=document.querySelector('[data-field="Salutation__c"]').value || '';
        var nm=document.querySelector('[data-field="Name__c"]').value || '';
        var full=(sal?sal+' ':'')+nm;
        $('dpName').textContent = nm ? full : '\u2014';
        $('dpName2').textContent = nm ? full : '\u2014';
        $('dpMobile').textContent = $('primaryPhone').value || '\u2014';
        $('dpEmail').textContent = $('emailField').value || '\u2014';
        $('dpAddress').textContent = buildPermAddr() || '\u2014';
    }
    ['Salutation__c','Name__c'].forEach(function(f){
        var el=document.querySelector('[data-field="'+f+'"]');
        if(el){ el.addEventListener('change', refreshDpdp); el.addEventListener('keyup', refreshDpdp); }
    });
    ['primaryPhone','emailField','houseNo','permLine','permDistrict','permState','permPin'].forEach(function(id){
        var el=$(id); if(el){ el.addEventListener('keyup', refreshDpdp); el.addEventListener('change', refreshDpdp); }
    });
    $('dpDate').textContent = new Date().toLocaleDateString('en-GB');

    // #1 Auto-populate +91 country code as a visual prefix on phone fields
    var tels = document.querySelectorAll('input[type=tel]');
    for (var t=0; t<tels.length; t++){
        (function(inp){
            var wrap=document.createElement('div');
            wrap.style.display='flex'; wrap.style.alignItems='stretch';
            var cc=document.createElement('span');
            cc.textContent='+91';
            cc.style.cssText='display:flex;align-items:center;padding:0 .6rem;border:1px solid #c9c7c5;border-right:none;border-radius:.25rem 0 0 .25rem;background:#f3f3f3;color:#3e3e3c;font-size:.95rem;';
            inp.parentNode.insertBefore(wrap, inp);
            wrap.appendChild(cc); wrap.appendChild(inp);
            inp.style.borderRadius='0 .25rem .25rem 0';
            inp.style.borderLeft='none';
        })(tels[t]);
    }

    // ---- Indian States / UTs for the address dropdowns ----
    var INDIAN_STATES = ['Andhra Pradesh','Arunachal Pradesh','Assam','Bihar','Chhattisgarh','Goa','Gujarat','Haryana','Himachal Pradesh','Jharkhand','Karnataka','Kerala','Madhya Pradesh','Maharashtra','Manipur','Meghalaya','Mizoram','Nagaland','Odisha','Punjab','Rajasthan','Sikkim','Tamil Nadu','Telangana','Tripura','Uttar Pradesh','Uttarakhand','West Bengal','Andaman and Nicobar Islands','Chandigarh','Dadra and Nagar Haveli and Daman and Diu','Delhi','Jammu and Kashmir','Ladakh','Lakshadweep','Puducherry'];
    ['permState','commState'].forEach(function(id){
        var sel=$(id); if(!sel) return;
        INDIAN_STATES.forEach(function(s){ var o=document.createElement('option'); o.value=s; o.textContent=s; sel.appendChild(o); });
    });

    // ---- Build a standard address string from the structured fields ----
    function buildAddr(houseNo, line, district, state, pin){
        var parts=[];
        if(houseNo && houseNo.trim()) parts.push(houseNo.trim());
        if(line && line.trim()) parts.push(line.trim());
        if(district && district.trim()) parts.push(district.trim());
        if(state && state.trim()) parts.push(state.trim());
        var s=parts.join(', ');
        if(pin && pin.trim()) s += (s ? ' - ' : '') + pin.trim();
        return s;
    }
    function buildPermAddr(){
        return buildAddr($('houseNo').value, $('permLine').value, $('permDistrict').value, $('permState').value, $('permPin').value);
    }

    // ---- Inline pattern validation (PAN / Aadhaar / phone / pin) ----
    var PATTERNS = {
        pan:     { re:/^[A-Z]{5}[0-9]{4}[A-Z]$/, norm:function(v){ return v.toUpperCase().replace(/[^A-Z0-9]/g,''); } },
        aadhaar: { re:/^[0-9]{12}$/,             norm:function(v){ return v.replace(/\D/g,''); } },
        phone:   { re:/^[6-9][0-9]{9}$/,         norm:function(v){ return v.replace(/\D/g,''); } },
        pin:     { re:/^[0-9]{6}$/,              norm:function(v){ return v.replace(/\D/g,''); } }
    };
    function checkField(inp){
        var kind=inp.getAttribute('data-validate'); if(!kind) return true;
        var p=PATTERNS[kind]; if(!p) return true;
        if(p.norm){ var nv=p.norm(inp.value); if(nv!==inp.value) inp.value=nv; }
        var hint=inp.parentNode.querySelector('.eoi-fielderr');
        if(inp.value===''){ inp.classList.remove('invalid'); if(hint) hint.classList.add('hidden'); return true; }
        var okk=p.re.test(inp.value);
        if(okk){ inp.classList.remove('invalid'); if(hint) hint.classList.add('hidden'); }
        else { inp.classList.add('invalid'); if(hint) hint.classList.remove('hidden'); }
        return okk;
    }
    var vfields=document.querySelectorAll('[data-validate]');
    for(var vi=0; vi<vfields.length; vi++){
        (function(inp){
            inp.addEventListener('input', function(){ checkField(inp); });
            inp.addEventListener('blur',  function(){ checkField(inp); });
        })(vfields[vi]);
    }
    function validatePatterns(){
        var all=true, firstBad=null;
        var fs=document.querySelectorAll('[data-validate]');
        for(var i=0;i<fs.length;i++){
            if(fs[i].value!=='' && !checkField(fs[i])){ all=false; if(!firstBad) firstBad=fs[i]; }
        }
        return { ok:all, firstBad:firstBad };
    }

    // #13 Channel Partner search -> reliable click-to-select dropdown (replaces flaky <datalist>)
    var cpSearch=$('cpSearch');
    var cpResults=$('cpResults');
    if(cpSearch && cpResults){
        var cpTimer=null;

        function cpRender(list){
            cpResults.innerHTML='';
            if(!list || !list.length){
                var none=document.createElement('div');
                none.textContent='No approved partners found';
                none.style.cssText='padding:10px 12px;color:#667085;font-size:13px;';
                cpResults.appendChild(none);
                cpResults.className=''; // show
                return;
            }
            for(var i=0;i<list.length;i++){
                (function(item){
                    var row=document.createElement('div');
                    row.textContent=item.label;
                    row.style.cssText='padding:10px 12px;cursor:pointer;font-size:14px;border-bottom:1px solid #f0f0f0;';
                    row.onmouseover=function(){ row.style.background='#eef4ff'; };
                    row.onmouseout=function(){ row.style.background='#fff'; };
                    row.onmousedown=function(e){ // mousedown fires before blur, so the pick registers
                        e.preventDefault();
                        $('cpId').value=item.value;
                        cpSearch.value=item.label;
                        if($('cpName')) $('cpName').value=item.label;
                        cpResults.className='hidden';
                    };
                    cpResults.appendChild(row);
                })(list[i]);
            }
            cpResults.className=''; // show
        }

        function cpSearchNow(){
            var term=cpSearch.value || '';
            Visualforce.remoting.Manager.invokeAction(
                '{!$RemoteAction.EOIFormSiteController.searchChannelPartners}',
                term,
                function(result, event){
                    if(!event.status){ return; }
                    var list; try{ list=JSON.parse(result); }catch(e){ list=[]; }
                    cpRender(list);
                }, {escape:false}
            );
        }

        cpSearch.addEventListener('focus', cpSearchNow); // show full list on click, no typing needed
        cpSearch.addEventListener('input', function(){
            $('cpId').value=''; // typing invalidates a prior pick
            if(cpTimer) clearTimeout(cpTimer);
            cpTimer=setTimeout(cpSearchNow, 200);
        });
        document.addEventListener('click', function(e){ // close when clicking elsewhere
            if(e.target!==cpSearch && !cpResults.contains(e.target)){ cpResults.className='hidden'; }
        });
    }

    // Source Type -> Secondary Source dependency (Channel Partner / Dealer fixed; Walkin / Referral from Lead)
    var srcMap={};
    Visualforce.remoting.Manager.invokeAction(
        '{!$RemoteAction.EOIFormSiteController.getSourceDependencyJson}',
        function(result, event){
            if(!event.status || !result) return;
            var data; try{ data=JSON.parse(result); }catch(e){ return; }
            srcMap=data.map||{};
            var st=$('sourceType');
            (data.sourceTypes||[]).forEach(function(s){
                var o=document.createElement('option'); o.value=s.value; o.textContent=s.label; st.appendChild(o);
            });
        }, {escape:false}
    );
    var stSel=$('sourceType');
    if(stSel){
        stSel.addEventListener('change', function(){
            var sec=$('secondarySource'); sec.innerHTML='<option value="">-- Select --</option>';
            var vals=srcMap[stSel.value]||[];
            vals.forEach(function(v){ var o=document.createElement('option'); o.value=v; o.textContent=v; sec.appendChild(o); });
        });
    }

    var MAX = 3*1024*1024;
    var fileInputs = document.querySelectorAll('input[type=file]');
    for (var fi=0; fi<fileInputs.length; fi++) {
        (function(inp){
            inp.addEventListener('change', function(){
                var cat=inp.getAttribute('data-category');
                var f=inp.files && inp.files[0];
                if(!f) return;
                if(f.size>MAX){ showError(f.name+' is larger than 3 MB. Please upload a smaller file.'); inp.value=''; return; }
                var isImg=(f.type||'').indexOf('image/')===0;
                var reader=new FileReader();
                reader.onerror=function(){ showError('Could not read '+f.name); };
                reader.onload=function(){
                    var dataUrl=String(reader.result||'');
                    var c=dataUrl.indexOf(',');
                    var b64=c>=0?dataUrl.substring(c+1):'';
                    if(!b64){ showError(f.name+' read as empty.'); return; }
                    files[cat]={fileName:f.name, title:cat, base64:b64};
                    clearError();
                    renderPreview(cat, f.name, isImg?dataUrl:null);
                };
                reader.readAsDataURL(f);
            });
        })(fileInputs[fi]);
    }
    function renderPreview(cat, name, imgUrl){
        var box=$('filePreview');
        var id='pv_'+cat.replace(/[^a-z0-9]/gi,'');
        var row=$(id);
        if(!row){ row=document.createElement('div'); row.id=id; row.style.margin='.4rem 0'; row.style.color='#2e844a'; row.style.fontSize='.85rem'; box.appendChild(row); }
        row.innerHTML='';
        var span=document.createElement('span'); span.textContent=cat+': '+name; row.appendChild(span);
        if(imgUrl){ var img=document.createElement('img'); img.src=imgUrl; img.className='eoi-thumb'; row.appendChild(img); }
    }

    function gather(){
        var rec={};
        var els=document.querySelectorAll('[data-field]');
        for (var i=0;i<els.length;i++){
            var el=els[i]; var key=el.getAttribute('data-field');
            if(el.type==='checkbox'){ rec[key]=el.checked; continue; }
            if(el.closest('.hidden')) continue;
            var v=el.value;
            if(v!==null && v!==undefined && v!=='') rec[key]=v;
        }
        return rec;
    }

    function validate(){
        clearError();
        var ok=true, firstBad=null;
        var req=document.querySelectorAll('[data-required="1"]');
        for(var i=0;i<req.length;i++){
            if(!req[i].value){ ok=false; req[i].style.borderColor='#c23934'; if(!firstBad) firstBad=req[i]; }
            else { req[i].style.borderColor='#c9c7c5'; }
        }
        if(!ok){ showError('Please complete the highlighted required fields.'); if(firstBad) firstBad.focus(); return false; }
        var pv=validatePatterns();
        if(!pv.ok){ showError('Please correct the highlighted fields - check the format shown below each one.'); if(pv.firstBad) pv.firstBad.focus(); return false; }
        if(!$('declCheck').checked){ showError('Please accept the Declaration before submitting.'); return false; }
        if(!$('dpdpCheck').checked){ showError('Please provide DPDP consent before submitting.'); return false; }
        return true;
    }

    function gatherLead(){
        return {
            sourceType: ($('sourceType')||{}).value || '',
            secondary:  ($('secondarySource')||{}).value || '',
            tertiary:   ($('tertiarySource')||{}).value || ''
        };
    }

    function submit(){
        if(!validate()) return;
        var btn=$('submitBtn'); btn.disabled=true; btn.textContent='Submitting...';
        var rec=gather();
        // Combine the structured address fields into the standard address text
        rec.Permanent_Address__c = buildPermAddr();
        var commAddr = buildAddr('', $('commLine').value, $('commDistrict').value, $('commState').value, $('commPin').value);
        if(commAddr) rec.Communication_Address__c = commAddr;
        var fileArr=Object.keys(files).map(function(k){ return files[k]; });
        Visualforce.remoting.Manager.invokeAction(
            '{!$RemoteAction.EOIFormSiteController.submitEOIRemote}',
            JSON.stringify(rec),
            JSON.stringify(fileArr),
            JSON.stringify(gatherLead()),
            function(result, event){
                if(event.status && result){
                    var r; try { r = JSON.parse(result); } catch(e){ r = {recordId: result, attached: 0}; }
                    done(r.recordId, r.attached);
                } else {
                    btn.disabled=false; btn.textContent='Submit Expression of Interest';
                    showError((event && event.message) ? event.message : 'Submission failed. Please try again.');
                }
            },
            {escape:false, timeout:120000}
        );
    }

    function done(recordId, attached){
        $('tyRef').textContent=recordId;
        $('tyFiles').textContent=attached;
        hide($('eoiForm'));
        show($('eoiThankYou'));
        window.scrollTo({top:0,behavior:'smooth'});
    }

    window.EOI={ submit: submit };
})();
</script>
</body>
</html>
</apex:page>