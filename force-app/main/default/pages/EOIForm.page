<apex:page controller="EOIFormSiteController" showHeader="false" sidebar="false"
           standardStylesheets="false" applyHtmlTag="false" applyBodyTag="false"
           docType="html-5.0" cache="false" title="Expression of Interest - Codename X">
<html xmlns="http://www.w3.org/1999/xhtml" lang="en">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover"/>
    <apex:slds />
    <style>
        html, body { margin:0; padding:0; background:#f3f3f3; width:100%; overflow-x:hidden;
            -webkit-text-size-adjust:100%; font-family:Arial, sans-serif; color:#16325c; }
        * { box-sizing:border-box; }
        .eoi-wrapper { max-width:920px; margin:0 auto; padding:1rem; }
        .eoi-header { text-align:center; padding:1.5rem 1rem; margin-bottom:1rem; border-bottom:3px solid #1f4e9c; }
        .eoi-title { font-size:1.75rem; font-weight:700; color:#1f4e9c; margin:0; }
        .eoi-subtitle { font-size:1rem; color:#54698d; margin-top:.25rem; }
        .eoi-card { background:#fff; border:1px solid #dddbda; border-radius:.5rem; padding:1.5rem;
            margin-bottom:1.25rem; box-shadow:0 2px 4px rgba(0,0,0,.04); }
        .eoi-section-title { font-size:1.25rem; font-weight:700; color:#1f4e9c; margin:0 0 1rem;
            padding-bottom:.5rem; border-bottom:1px solid #e5e5e5; }
        .eoi-subsection { margin-top:1.25rem; padding-top:1rem; border-top:1px dashed #e0e0e0; }
        .eoi-subsection-title { font-size:1rem; font-weight:600; color:#2e5aac; margin:0 0 .75rem; }
        .eoi-field { margin-bottom:.75rem; }
        .eoi-field label { display:block; font-size:.8rem; font-weight:600; margin-bottom:.25rem; color:#3e3e3c; }
        .eoi-field .req { color:#c23934; }
        .eoi-input, .eoi-select, .eoi-textarea { width:100%; padding:.5rem .65rem; font-size:.95rem;
            border:1px solid #c9c7c5; border-radius:.25rem; background:#fff; }
        .eoi-textarea { min-height:70px; resize:vertical; }
        .eoi-input:focus, .eoi-select:focus, .eoi-textarea:focus { outline:none; border-color:#1f4e9c; box-shadow:0 0 0 1px #1f4e9c; }
        .eoi-check { display:flex; align-items:center; gap:.5rem; margin:.4rem 0; font-size:.9rem; }
        .eoi-muted { color:#706e6b; font-size:.85rem; margin-bottom:.75rem; }
        .eoi-note { font-size:.78rem; color:#706e6b; font-style:italic; }
        .eoi-legal { background:#f7f9fb; border-left:3px solid #1f4e9c; padding:.75rem 1rem;
            border-radius:.25rem; font-size:.85rem; line-height:1.5; color:#3e3e3c; margin-bottom:.75rem; }
        .eoi-bold { font-weight:700; margin-top:.75rem; }
        .eoi-legal ol, .eoi-legal ul { margin:.25rem 0 .5rem 1.25rem; padding:0; }
        .eoi-legal li { margin-bottom:.35rem; }
        .eoi-principal { background:#fff; border:1px solid #c9c7c5; border-radius:.25rem;
            padding:.6rem .85rem; margin:.4rem 0; font-size:.9rem; line-height:1.7; }
        .eoi-principal-label { display:inline-block; min-width:120px; color:#54698d; }
        .eoi-file-input { display:block; width:100%; font-size:.85rem; padding:.4rem 0; }
        .eoi-thumb { width:56px; height:56px; object-fit:cover; border:1px solid #dddbda;
            border-radius:.25rem; background:#fff; vertical-align:middle; margin-left:.5rem; }
        .eoi-table-scroll { width:100%; overflow-x:auto; }
        .eoi-ref-table { width:100%; min-width:640px; border-collapse:collapse; font-size:.82rem; }
        .eoi-ref-table th, .eoi-ref-table td { border:1px solid #dddbda; padding:.5rem .6rem; text-align:left; vertical-align:top; }
        .eoi-ref-table th { background:#1f4e9c; color:#fff; font-weight:600; white-space:nowrap; }
        .eoi-ref-table tbody tr:nth-child(even) { background:#f7f9fb; }
        .eoi-table { width:100%; border-collapse:collapse; font-size:.9rem; margin-top:.25rem; }
        .eoi-table td { border:1px solid #dddbda; padding:.5rem .75rem; }
        .eoi-table td:last-child { text-align:right; font-weight:600; white-space:nowrap; }
        .eoi-note-card { background:#fffaf0; border-color:#e0c98c; }
        .eoi-note-card p { margin:.25rem 0; font-size:.85rem; color:#5c4a1a; }
        .eoi-btn { background:#1f4e9c; color:#fff; border:none; border-radius:.25rem;
            padding:.75rem 1.75rem; font-size:1rem; font-weight:600; cursor:pointer; }
        .eoi-btn:disabled { opacity:.6; cursor:default; }
        .eoi-actions { text-align:center; margin:1.5rem 0 3rem; }
        .eoi-error { background:#fdf2f2; border:1px solid #c23934; color:#c23934; padding:.75rem 1rem;
            border-radius:.25rem; margin-bottom:1rem; font-size:.9rem; }
        .eoi-success { text-align:center; border-color:#2e844a; }
        .eoi-success .eoi-section-title { color:#2e844a; border:none; }
        .row { display:flex; flex-wrap:wrap; margin:0 -.5rem; }
        .col { padding:0 .5rem; flex:1 1 100%; }
        .col-2 { padding:0 .5rem; flex:1 1 50%; max-width:50%; }
        .col-3 { padding:0 .5rem; flex:1 1 33.333%; max-width:33.333%; }
        .hidden { display:none; }
        @media (max-width:768px) {
            .eoi-wrapper { padding:.5rem; }
            .eoi-card { padding:1rem; }
            .eoi-title { font-size:1.4rem; }
            .eoi-section-title { font-size:1.1rem; }
            .col-2, .col-3 { flex:1 1 100%; max-width:100%; }
            .eoi-principal-label { min-width:84px; }
            .eoi-btn { width:100%; }
        }
        /* ---- Visual polish ---- */
        body { background:linear-gradient(180deg,#eaf0f8 0%, #f3f3f3 260px, #f3f3f3 100%); }
        .eoi-header { background:linear-gradient(135deg,#1f4e9c 0%, #2e6fd6 100%); border:none;
            border-radius:14px; padding:1.9rem 1rem; box-shadow:0 10px 28px rgba(31,78,156,.25); }
        .eoi-title { color:#fff; letter-spacing:.3px; }
        .eoi-subtitle { color:#dbe6f8; }
        .eoi-card { border:1px solid #e7eaf0; border-radius:14px; box-shadow:0 4px 16px rgba(22,50,92,.06);
            transition:box-shadow .2s ease; }
        .eoi-card:hover { box-shadow:0 8px 26px rgba(22,50,92,.10); }
        .eoi-section-title { position:relative; padding-left:.8rem; border-bottom:1px solid #eef0f4; }
        .eoi-section-title::before { content:""; position:absolute; left:0; top:.15rem; bottom:.6rem; width:4px;
            border-radius:3px; background:linear-gradient(180deg,#1f4e9c,#2e6fd6); }
        .eoi-subsection { border-top:1px dashed #dfe3ea; }
        .eoi-subsection-title { color:#1f4e9c; }
        .eoi-input, .eoi-select, .eoi-textarea { border:1px solid #d7dbe3; border-radius:8px; padding:.6rem .7rem;
            transition:border-color .15s ease, box-shadow .15s ease; }
        .eoi-input:focus, .eoi-select:focus, .eoi-textarea:focus { border-color:#2e6fd6;
            box-shadow:0 0 0 3px rgba(46,111,214,.15); }
        .eoi-input.invalid, .eoi-select.invalid { border-color:#c23934; box-shadow:0 0 0 3px rgba(194,57,52,.12); }
        .eoi-fielderr { color:#c23934; font-size:.72rem; margin-top:.25rem; line-height:1.3; }
        .eoi-btn { background:linear-gradient(135deg,#1f4e9c,#2e6fd6); border-radius:10px; padding:.85rem 2.2rem;
            box-shadow:0 6px 18px rgba(31,78,156,.3); transition:transform .15s ease, box-shadow .15s ease, filter .15s ease; }
        .eoi-btn:hover:not(:disabled) { transform:translateY(-1px); filter:brightness(1.06);
            box-shadow:0 10px 24px rgba(31,78,156,.36); }
        .eoi-success { border:1px solid #b6e2c4; box-shadow:0 4px 16px rgba(46,132,74,.10); }
    </style>
</head>
<body>
<div class="eoi-wrapper">
    <div class="eoi-header">
        <h1 class="eoi-title">Expression of Interest</h1>
        <p class="eoi-subtitle">Codename X &mdash; Nelamangala &ndash; Chikkaballapura Road, Bangalore</p>
    </div>

    <div id="eoiError" class="eoi-error hidden"></div>

    <div id="eoiThankYou" class="eoi-card eoi-success hidden">
        <h2 class="eoi-section-title">Thank you!</h2>
        <p>Your Expression of Interest has been submitted successfully.</p>
        <p>Reference ID: <strong id="tyRef"></strong></p>
        <p class="eoi-muted">Documents attached: <span id="tyFiles"></span></p>
        <p class="eoi-muted">Our team will get in touch with you shortly.</p>
    </div>

    <div id="eoiForm">
        <!-- PROJECT (auto-populated, read-only) -->
        <div class="eoi-card">
            <div class="eoi-field"><label>Project Name</label>
                <input class="eoi-input" type="text" data-field="Project_Name__c" value="Codename X" readonly="readonly" style="background:#f3f3f3; font-weight:600;"/></div>
        </div>

        <!-- APPLICANT -->
        <div class="eoi-card">
            <h2 class="eoi-section-title">Applicant Details</h2>
            <div class="row">
                <div class="col-3 eoi-field">
                    <label>Salutation <span class="req">*</span></label>
                    <select class="eoi-select" data-field="Salutation__c" data-required="1">
                        <apex:repeat value="{!salutationOptions}" var="o"><option value="{!o.value}">{!o.label}</option></apex:repeat>
                    </select>
                </div>
                <div class="col-2 eoi-field"><label>Full Name <span class="req">*</span></label>
                    <input class="eoi-input" type="text" data-field="Name__c" data-required="1" maxlength="120"/></div>
                <div class="col-3 eoi-field"><label>S/O, D/O</label>
                    <input class="eoi-input" type="text" data-field="S_o_D_o__c"/></div>
                <div class="col-3 eoi-field"><label>Date of Birth <span class="req">*</span></label>
                    <input class="eoi-input" type="date" data-field="Date_of_Birth__c" data-required="1"/></div>
                <div class="col-3 eoi-field"><label>Country of Residence <span class="req">*</span></label>
                    <input class="eoi-input" type="text" data-field="Country_of_Residence__c" data-required="1"/></div>
                <div class="col-3 eoi-field"><label>Passport No. (PIO / NRI)</label>
                    <input class="eoi-input" type="text" data-field="Passport_Number_PIO__c"/></div>
                <div class="col-2 eoi-field"><label>Aadhaar No. <span class="req">*</span></label>
                    <input class="eoi-input" type="text" data-field="Aadhaar_Number__c" data-required="1" data-validate="aadhaar" inputmode="numeric" maxlength="12"/>
                    <div class="eoi-fielderr hidden">Enter a valid 12-digit Aadhaar number.</div></div>
                <div class="col-2 eoi-field"><label>PAN No. <span class="req">*</span></label>
                    <input class="eoi-input" type="text" data-field="PAN_Number__c" data-required="1" data-validate="pan" maxlength="10" style="text-transform:uppercase;"/>
                    <div class="eoi-fielderr hidden">Format: ABCDE1234F (5 letters, 4 digits, 1 letter).</div></div>
                <div class="col-2 eoi-field"><label>Primary Contact No. <span class="req">*</span></label>
                    <input class="eoi-input" type="tel" data-field="Primary_Contact_No__c" data-required="1" data-validate="phone" inputmode="numeric" maxlength="10" id="primaryPhone"/>
                    <div class="eoi-fielderr hidden">Enter a valid 10-digit mobile number starting with 6-9.</div></div>
                <div class="col-2 eoi-field"><label>Alternate Contact No.</label>
                    <input class="eoi-input" type="tel" data-field="Alternate_Contact_No__c" data-validate="phone" inputmode="numeric" maxlength="10"/>
                    <div class="eoi-fielderr hidden">Enter a valid 10-digit mobile number starting with 6-9.</div></div>
                <div class="col eoi-field"><label>Email <span class="req">*</span></label>
                    <input class="eoi-input" type="email" data-field="Email__c" data-required="1" id="emailField"/></div>
            </div>

            <!-- Permanent Address (structured; combined into the address field on submit) -->
            <div class="eoi-subsection">
                <h3 class="eoi-subsection-title">Permanent Address</h3>
                <div class="row">
                    <div class="col-2 eoi-field"><label>House No. / Building <span class="req">*</span></label>
                        <input class="eoi-input" type="text" id="houseNo" data-required="1" maxlength="120"/></div>
                    <div class="col-2 eoi-field"><label>Street / Area / Locality <span class="req">*</span></label>
                        <input class="eoi-input" type="text" id="permLine" data-required="1" maxlength="255"/></div>
                    <div class="col-2 eoi-field"><label>District <span class="req">*</span></label>
                        <input class="eoi-input" type="text" id="permDistrict" data-required="1" maxlength="80"/></div>
                    <div class="col-2 eoi-field"><label>State <span class="req">*</span></label>
                        <select class="eoi-select" id="permState" data-required="1"><option value="">-- Select --</option></select></div>
                    <div class="col-2 eoi-field"><label>Pincode <span class="req">*</span></label>
                        <input class="eoi-input" type="text" data-field="Permanent_Pincode__c" id="permPin" data-required="1" data-validate="pin" inputmode="numeric" maxlength="6"/>
                        <div class="eoi-fielderr hidden">Enter a valid 6-digit pincode.</div></div>
                </div>
            </div>

            <!-- Communication Address (optional; combined on submit) -->
            <div class="eoi-subsection">
                <h3 class="eoi-subsection-title">Communication Address <span style="font-weight:400;font-size:.78rem;color:#706e6b;">(if different from permanent)</span></h3>
                <div class="row">
                    <div class="col-2 eoi-field"><label>Street / Area / Locality</label>
                        <input class="eoi-input" type="text" id="commLine" maxlength="255"/></div>
                    <div class="col-2 eoi-field"><label>District</label>
                        <input class="eoi-input" type="text" id="commDistrict" maxlength="80"/></div>
                    <div class="col-2 eoi-field"><label>State</label>
                        <select class="eoi-select" id="commState"><option value="">-- Select --</option></select></div>
                    <div class="col-2 eoi-field"><label>Pincode</label>
                        <input class="eoi-input" type="text" data-field="Communication_Pincode__c" id="commPin" data-validate="pin" inputmode="numeric" maxlength="6"/>
                        <div class="eoi-fielderr hidden">Enter a valid 6-digit pincode.</div></div>
                </div>
            </div>
        </div>

        <!-- PROFESSIONAL -->
        <div class="eoi-card">
            <h2 class="eoi-section-title">Professional Details</h2>
            <div class="row">
                <div class="col-2 eoi-field"><label>Profession <span class="req">*</span></label>
                    <select class="eoi-select" data-field="Profession__c" data-required="1"><option value="">-- Select --</option>
                        <apex:repeat value="{!professionOptions}" var="o"><option value="{!o.value}">{!o.label}</option></apex:repeat>
                        <option value="Homemaker">Homemaker</option>
                        <option value="Retired">Retired</option>
                        <option value="Others">Others</option></select></div>
                <div class="col-2 eoi-field"><label>Company / Firm Name</label>
                    <input class="eoi-input" type="text" data-field="Company_Firm_Name__c"/></div>
                <div class="col-2 eoi-field"><label>Designation</label>
                    <input class="eoi-input" type="text" data-field="Designation__c"/></div>
                <div class="col-2 eoi-field"><label>Office Pincode</label>
                    <input class="eoi-input" type="text" data-field="Pincode__c" maxlength="6"/></div>
                <div class="col eoi-field"><label>Office Address</label>
                    <textarea class="eoi-textarea" data-field="Office_Address__c"></textarea></div>
                <div class="col-2 eoi-field"><label>Qualification</label>
                    <select class="eoi-select" data-field="Qualification__c" id="qualSelect"><option value="">-- Select --</option>
                        <apex:repeat value="{!qualificationOptions}" var="o"><option value="{!o.value}">{!o.label}</option></apex:repeat></select></div>
                <div class="col-2 eoi-field hidden" id="otherQualWrap"><label>Other Qualification</label>
                    <input class="eoi-input" type="text" data-field="Other_Qualification__c"/></div>
            </div>
        </div>

        <!-- OTHER -->
        <div class="eoi-card">
            <h2 class="eoi-section-title">Other Details</h2>
            <div class="row">
                <div class="col-2 eoi-field"><label>Annual Household Income</label>
                    <select class="eoi-select" data-field="Annual_Household_Income__c"><option value="">-- Select --</option>
                        <apex:repeat value="{!incomeOptions}" var="o"><option value="{!o.value}">{!o.label}</option></apex:repeat></select></div>
                <div class="col-2 eoi-field"><label>Purpose of Purchase</label>
                    <select class="eoi-select" data-field="Purpose_of_Purchase__c" id="purposeSelect"><option value="">-- Select --</option>
                        <apex:repeat value="{!purposeOptions}" var="o"><option value="{!o.value}">{!o.label}</option></apex:repeat></select></div>
                <div class="col eoi-field hidden" id="otherPurposeWrap"><label>Other Purpose</label>
                    <input class="eoi-input" type="text" data-field="Other_Purpose__c"/></div>
                <div class="col-2 eoi-field"><label>How did you get to know about us? <span class="req">*</span></label>
                    <select class="eoi-select" data-field="How_did_you_get_to_know_about_us__c" id="howKnowSelect" data-required="1"><option value="">-- Select --</option>
                        <apex:repeat value="{!howKnowOptions}" var="o"><option value="{!o.value}">{!o.label}</option></apex:repeat></select></div>
                <div class="col-2 eoi-field hidden" id="otherSourceWrap"><label>Please specify source</label>
                    <input class="eoi-input" type="text" data-field="Others_Source__c"/></div>
            </div>

            <!-- Source Type -> Secondary Source -> Tertiary Source (mapped to the Lead) -->
            <div class="eoi-subsection">
                <h3 class="eoi-subsection-title">Source Details</h3>
                <div class="row">
                    <div class="col-2 eoi-field"><label>Source Type</label>
                        <select class="eoi-select" id="sourceType"><option value="">-- Select --</option></select></div>
                    <div class="col-2 eoi-field"><label>Secondary Source</label>
                        <select class="eoi-select" id="secondarySource"><option value="">-- Select --</option></select></div>
                    <div class="col-2 eoi-field"><label>Tertiary Source (Name)</label>
                        <input class="eoi-input" type="text" id="tertiarySource" placeholder="Channel Partner / Referral / Dealer name"/></div>
                </div>
            </div>

            <div class="eoi-subsection">
                <h3 class="eoi-subsection-title">If Referred by Friend / Relative / Owner</h3>
                <div class="row">
                    <div class="col-2 eoi-field"><label>Name</label><input class="eoi-input" type="text" data-field="Friend_Relative_Self_Referrer_Name__c"/></div>
                    <div class="col-2 eoi-field"><label>Project Name</label><input class="eoi-input" type="text" data-field="Referrer_Project_Name__c"/></div>
                    <div class="col-2 eoi-field"><label>Contact No.</label><input class="eoi-input" type="tel" data-field="Referrer_Contact_No__c" maxlength="10"/></div>
                    <div class="col-2 eoi-field"><label>Email ID</label><input class="eoi-input" type="email" data-field="Referrer_Email__c"/></div>
                </div>
            </div>

            <div class="eoi-subsection">
                <h3 class="eoi-subsection-title">If Referred by Channel Partner</h3>
                <div class="row">
                    <div class="col-2 eoi-field" style="position:relative;"><label>Approved CP Name (search)</label>
                        <input class="eoi-input" type="text" id="cpSearch" autocomplete="off" placeholder="Type to search approved partners"/>
                        <div id="cpResults" class="hidden" style="position:absolute;z-index:50;left:0;right:0;top:100%;background:#fff;border:1px solid #d0d5dd;border-top:none;border-radius:0 0 6px 6px;max-height:220px;overflow-y:auto;box-shadow:0 6px 18px rgba(0,0,0,0.12);"></div>
                        <input type="hidden" data-field="Channel_Partner__c" id="cpId"/></div>
                    <div class="col-2 eoi-field"><label>Name</label><input class="eoi-input" type="text" data-field="Channel_Partner_Name__c" id="cpName"/></div>
                    <div class="col-2 eoi-field"><label>Project Name</label><input class="eoi-input" type="text" data-field="Channel_Partner_Project_Name__c" value="Codename X"/></div>
                    <div class="col-2 eoi-field"><label>Contact No.</label><input class="eoi-input" type="tel" data-field="CP_Contact_No__c" maxlength="10"/></div>
                    <div class="col-2 eoi-field"><label>Email ID</label><input class="eoi-input" type="email" data-field="Channel_Partner_Email__c"/></div>
                    <div class="col eoi-field"><label>Sign and Seal (upload image)</label>
                        <input type="file" class="eoi-file-input" accept="image/*" data-category="Channel Partner Sign and Seal"/></div>
                </div>
            </div>

            <div class="eoi-subsection">
                <h3 class="eoi-subsection-title">If Corporate Activity</h3>
                <div class="eoi-field"><label>Company Name</label><input class="eoi-input" type="text" data-field="Corporate_Activity_Company_Name__c"/></div>
            </div>
        </div>

        <!-- UNIT PREFERENCES -->
        <div class="eoi-card">
            <h2 class="eoi-section-title">Unit Preferences</h2>
            <p class="eoi-muted">EOI price range: BSP &#8377;5,500 to &#8377;6,000 per sq. ft.</p>
            <div class="row">
                <div class="col-2 eoi-field"><label>Preferred PLC</label>
                    <select class="eoi-select" data-field="Preferred_PLC__c"><option value="">-- Select --</option><apex:repeat value="{!plcOptions}" var="o"><option value="{!o.value}">{!o.label}</option></apex:repeat></select></div>
                <div class="col-2 eoi-field"><label>Preferred Area</label>
                    <select class="eoi-select" data-field="Preferred_Area__c"><option value="">-- Select --</option><apex:repeat value="{!areaOptions}" var="o"><option value="{!o.value}">{!o.label}</option></apex:repeat></select></div>
                <div class="col-2 eoi-field"><label>Preferred Facing</label>
                    <select class="eoi-select" data-field="Preferred_Facing__c"><option value="">-- Select --</option><apex:repeat value="{!facingOptions}" var="o"><option value="{!o.value}">{!o.label}</option></apex:repeat></select></div>
                <div class="col-2 eoi-field"><label>Road Facing</label>
                    <select class="eoi-select" data-field="Road_Facing__c"><option value="">-- Select --</option><apex:repeat value="{!roadOptions}" var="o"><option value="{!o.value}">{!o.label}</option></apex:repeat></select></div>
                <div class="col-2"><label class="eoi-check"><input type="checkbox" data-field="Corner__c"/> Corner Plot</label></div>
                <div class="col-2"><label class="eoi-check"><input type="checkbox" data-field="Amenity_Garden_View__c"/> Amenity and Garden View</label></div>
            </div>

            <h3 class="eoi-subsection-title" style="margin-top:1rem;">Preferred Unit No.</h3>
            <div class="row">
                <div class="col-3 eoi-field"><label>Preference 1</label><input class="eoi-input" type="text" data-field="Preference_1__c"/></div>
                <div class="col-3 eoi-field"><label>Preference 2</label><input class="eoi-input" type="text" data-field="Preference_2__c"/></div>
