            margin: 0;
            padding: 0;
        }
        .header {
            text-align: center;
            font-weight: bold;
            margin-bottom: 10px;
        }
        table,
            th,
            td {
                border: 1px #C0C0C0;
            }
        .left-align {
            text-align: left;
        }
        .right-align {
            text-align: right;
        }
        .center-align {
            text-align: center;
        }
        .bold {
            font-weight: bold;
        }
        .indent {
            padding-left: 20px;
        }
        .total-row {
            font-weight: bold;
            background-color: #f2f2f2;
        }
        .page-break {
            page-break-after: always;
